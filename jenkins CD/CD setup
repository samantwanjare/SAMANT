# Step 9: Create Jenkins Pipeline

```groovy
pipeline {

 agent {
     label 'docker-agent'
 }

 environment {
     REGION='ap-south-1'
     ACCOUNT_ID='YOUR_ACCOUNT_ID'
     REPO='myapp'
 }

 stages {

    stage('Checkout'){
      steps{
        git 'https://github.com/user/repo.git'
      }
    }

    stage('Build'){
      steps{
        sh 'docker build -t myapp .'
      }
    }

    stage('Login ECR'){
      steps{
        sh '''
        aws ecr get-login-password --region $REGION \
        | docker login \
        --username AWS \
        --password-stdin \
        $ACCOUNT_ID.dkr.ecr.$REGION.amazonaws.com
        '''
      }
    }

    stage('Tag'){
      steps{
        sh '''
        docker tag myapp:latest \
        $ACCOUNT_ID.dkr.ecr.$REGION.amazonaws.com/$REPO:${BUILD_NUMBER}
        '''
      }
    }

    stage('Push'){
      steps{
        sh '''
        docker push \
        $ACCOUNT_ID.dkr.ecr.$REGION.amazonaws.com/$REPO:${BUILD_NUMBER}
        '''
      }
    }

 }
}
```

